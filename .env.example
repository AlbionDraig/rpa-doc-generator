# ==============================
# App / API
# ==============================
APP_TITLE=RPA Doc Generator
APP_VERSION=1.0.0
APP_DESCRIPTION=Generador automatico de documentacion SDD para bots de Automation Anywhere

APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
APP_ACCESS_LOG=true

# Base URL publica usada en respuesta del endpoint /
PUBLIC_BASE_URL=http://localhost:8000

# CORS (separado por comas)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000,http://127.0.0.1,http://127.0.0.1:3000

# ==============================
# Storage / Paths
# ==============================
OUTPUT_DIR=./output
TMP_DIR=./tmp
STATIC_DIR=./app/static

# ==============================
# Upload / Extraction limits
# ==============================
UPLOAD_CHUNK_SIZE=1048576
MAX_FILE_SIZE=1610612736
MAX_EXTRACTION_SIZE=1610612736

# ==============================
# AI Analysis (Quality + SDD)
# ==============================
AI_QUALITY_ENABLED=false
AI_TIMEOUT_SECONDS=25

# Groq (prioritario si GROQ_API_KEY existe)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# Capacity / Rate Limiting
# ==============================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX_REQUESTS=30
API_RATE_LIMIT_WINDOW_SECONDS=60
MAX_CONCURRENT_GENERATIONS=2
GENERATION_ACQUIRE_TIMEOUT_SECONDS=10
